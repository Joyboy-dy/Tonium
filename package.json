{
  "name": "tonium",
  "version": "2.0.0",
  "description": "A safe color-theme assistant for Next.js + Tailwind CSS v4 + shadcn/ui projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "tonium": "dist/bin/tonium.js"
  },
  "scripts": {
    "dev": "tsx src/bin/tonium.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/bin/tonium.js",
    "prepublishOnly": "npm run build",
    "release": "tsx scripts/release.ts"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "culori": "^4.0.2",
    "fs-extra": "^11.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
